[
  {
    "origin": ["*"],
    "method": ["GET", "POST", "PUT", "OPTIONS"],
    "responseHeader": [
      "Content-Type",
      "Authorization",
      "Content-Length",
      "User-Agent",
      "x-goog-resumable",
      "x-goog-meta-*",
      "x-firebase-gmpid",
      "x-firebase-appcheck"
    ],
    "maxAgeSeconds": 3600
  }
]
