rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /submissions/{questId}/{explorer}/{filename} {
      // Reads are required by getDownloadURL() on the client after upload.
      // Paths include a timestamp so they aren't trivially guessable, and
      // bucket-level listing remains denied by default.
      allow read;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
